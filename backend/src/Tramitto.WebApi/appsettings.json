{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/tramitto-.log",
          "rollingInterval": "Day"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "ConnectionStrings": {
    "PostgresConnection": "Host=localhost;Port=5432;Database=tramitto_db;Username=tramitto_user;Password=tramitto_pass"
  },
  "Jwt": {
    "Issuer": "tramitto-api",
    "Audience": "tramitto-client",
    "SecretKey": "CHANGE_THIS_SECRET_KEY_MIN_32_CHARS",
    "ExpirationHours": 5
  },
  "Minio": {
    "Host": "localhost:9000",
    "Username": "tramitto_minio",
    "Password": "tramitto_minio_pass",
    "IsSecureSSL": false
  },
  "Redis": {
    "ConnectionString": "localhost:6379"
  },
  "RabbitMQ": {
    "Host": "localhost",
    "Port": 5672,
    "Username": "tramitto_rabbit",
    "Password": "tramitto_rabbit_pass"
  },
  "AllowedHosts": "*"
}
